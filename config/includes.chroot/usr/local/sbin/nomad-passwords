#!/bin/bash
#
# nomad-passwords: runs once per boot (not once per USB — the RAM
# filesystem resets /etc/shadow on every boot, so we need to reset
# the password every boot too).
#
# live-config's user-setup component creates the nomad user but
# hardcodes the password hash for "live" (it has no variable for
# setting a custom password). Our job is to override that to "nomad".

set -e

# Only proceed if the nomad user exists. If user-setup hasn't run
# yet for some reason (shouldn't happen at multi-user.target but be
# defensive), fail loudly rather than silently.
if ! id nomad >/dev/null 2>&1; then
    echo "nomad-firstboot: user 'nomad' does not exist yet, aborting" >&2
    exit 1
fi

echo "nomad-firstboot: setting password for nomad user"
echo "nomad:nomad" | chpasswd

echo "nomad-firstboot: setting password for root user"
echo "root:nomad" | chpasswd

# Belt-and-suspenders: docker group membership. user-setup *should*
# handle this via LIVE_USER_DEFAULT_GROUPS, but in practice it was
# unreliable, so enforce it here too.
if getent group docker >/dev/null 2>&1; then
    usermod -a -G docker nomad
fi

echo "nomad-firstboot: complete"
