#!/bin/bash
#
# nomad-firstboot-ui: full-screen verbose UI for the very first boot.
#
# What this is:
# A wrapper around nomad-init.service's actual work that produces an
# unambiguous, easy-to-read "we are setting up, do not touch" screen
# on tty1. After init succeeds, we touch the .nomad-initialized flag
# and reboot. Subsequent boots skip this entirely (target conditional)
# and go straight to multi-user.target.
#
# Why a separate UI script (vs. just teaching nomad-init to draw to
# tty1):
#   - Keeps nomad-init logic-only and testable. It writes state to
#     /run/nomad-init.state; we just visualize that state.
#   - We can iterate on the UI without touching the load logic.
#   - Mirrors how `nomad watch` already reads the state file —
#     basically a different rendering of the same underlying view.

set -uo pipefail

NOMAD_VERSION="unknown"
[ -r /etc/nomad-version ] && NOMAD_VERSION=$(tr -d '[:space:]' < /etc/nomad-version)

INIT_SCRIPT="/usr/local/sbin/nomad-init"
FLAG_FILE="/mnt/nomad-data/.nomad-initialized"
STATE_FILE="/run/nomad-init.state"
PV_BYTES_FILE="/run/nomad-init.pv"

# Ensure we own tty1. Without this, anything else writing there
# (kernel messages, leftover login prompts) will corrupt our display.
exec </dev/tty1 >/dev/tty1 2>&1

# Disable kernel console messages on tty1 while we have the screen.
# Saved to a global so we can restore on exit. Any failure is fine —
# this is cosmetic. Level 1 = emergency only (panics still get through).
PREV_LOGLEVEL=$(awk '{print $1}' /proc/sys/kernel/printk 2>/dev/null || echo 4)
echo 1 > /proc/sys/kernel/printk 2>/dev/null || true

# Hide the cursor for the duration of the setup screen.
have_tput=0
command -v tput >/dev/null 2>&1 && have_tput=1
[ "$have_tput" = "1" ] && tput civis 2>/dev/null

cleanup() {
    echo "$PREV_LOGLEVEL" > /proc/sys/kernel/printk 2>/dev/null || true
    [ "$have_tput" = "1" ] && tput cnorm 2>/dev/null
}
trap cleanup EXIT

# ---- helpers ----
get_state() {
    local key="$1"
    [ -r "$STATE_FILE" ] || return 0
    grep "^${key}=" "$STATE_FILE" 2>/dev/null | tail -n1 | cut -d= -f2-
}

fmt_bytes() {
    local b="$1"
    if [ "$b" -ge 1073741824 ]; then
        printf '%d.%01d GB' $((b / 1073741824)) $(( (b * 10 / 1073741824) % 10 ))
    elif [ "$b" -ge 1048576 ]; then
        printf '%d MB' $((b / 1048576))
    else
        printf '%d KB' $((b / 1024))
    fi
}

fmt_dur() {
    local s="$1"
    if [ "$s" -le 0 ]; then printf '<1s'; return; fi
    local m=$((s / 60))
    local r=$((s % 60))
    if [ "$m" -gt 0 ]; then printf '%dm%02ds' "$m" "$r"
    else printf '%ds' "$r"; fi
}

bar() {
    local pct="$1"
    local width=50
    local filled=$(( pct * width / 100 ))
    [ "$filled" -gt "$width" ] && filled="$width"
    [ "$filled" -lt 0 ] && filled=0
    local empty=$((width - filled))
    local b=''
    local i=0
    while [ "$i" -lt "$filled" ]; do b="${b}█"; i=$((i+1)); done
    i=0
    while [ "$i" -lt "$empty" ]; do b="${b}░"; i=$((i+1)); done
    printf '%s' "$b"
}

# Print at row $1, content $2..., padded with clear-EOL.
line() {
    local row="$1"; shift
    [ "$have_tput" = "1" ] && tput cup "$row" 0
    printf '%b' "$*"
    [ "$have_tput" = "1" ] && tput el
}

# ---- the unchanging banner header ----
draw_banner() {
    [ "$have_tput" = "1" ] && clear
    cat <<EOF


   ╔══════════════════════════════════════════════════════════════════╗
   ║                                                                  ║
   ║          PROJECT NOMAD USB — FIRST-BOOT SETUP                    ║
   ║                                  v${NOMAD_VERSION}$(printf '%*s' $((36 - ${#NOMAD_VERSION})) '')║
   ║                                                                  ║
   ║   This is a one-time setup that takes 15-30 minutes.             ║
   ║   The system will reboot automatically when finished.            ║
   ║                                                                  ║
   ║   ⚠  DO NOT POWER OFF OR REMOVE THE USB DRIVE.                  ║
   ║                                                                  ║
   ║   You can SSH in for diagnostics:                                ║
   ║      User: nomad   Password: nomad                               ║
   ║      Run:  journalctl -u nomad-init -f                           ║
   ║                                                                  ║
   ╚══════════════════════════════════════════════════════════════════╝

EOF
}

draw_banner

# Spinner cycle for the active-image marker.
spinner_frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
frame_idx=0

# Start nomad-init in the background. We run it as the actual logic
# script (it writes to /run/nomad-init.state); our job is just to
# visualize. Stdout/stderr go to journald so the journal command
# referenced in the banner actually finds something.
systemd-cat -t nomad-init -p info "$INIT_SCRIPT" &
INIT_PID=$!

# Render loop — refresh ~4x/sec until init exits.
PROGRESS_ROW=20      # row where the dynamic content starts
while kill -0 "$INIT_PID" 2>/dev/null; do
    spinner="${spinner_frames[$frame_idx]}"
    frame_idx=$(( (frame_idx + 1) % ${#spinner_frames[@]} ))

    init_phase=$(get_state phase)
    expected=$(get_state expected_images); expected=${expected:-0}
    loaded_count=$(get_state loaded_count); loaded_count=${loaded_count:-0}
    eta_sec=$(get_state eta_sec)
    images_csv=$(get_state images)
    done_csv=$(get_state done_images)
    cur_size=$(get_state current_tarball_size); cur_size=${cur_size:-0}

    cur_bytes=0
    if [ -r "$PV_BYTES_FILE" ]; then
        cur_bytes=$(tail -n1 "$PV_BYTES_FILE" 2>/dev/null | tr -d ' \r' || echo 0)
        cur_bytes=${cur_bytes//[^0-9]/}; cur_bytes=${cur_bytes:-0}
    fi

    row=$PROGRESS_ROW

    case "$init_phase" in
        ""|init)
            line $row "   $spinner  Starting up..."
            row=$((row+1))
            ;;
        reading|unpacking)
            if [ "$init_phase" = "reading" ] && [ "$cur_size" -gt 0 ] \
               && [ "$cur_bytes" -lt "$cur_size" ]; then
                pct=$(( cur_bytes * 100 / cur_size ))
                line $row "   $spinner  Reading tarball into Docker"
                row=$((row+1))
                line $row "   [$(bar $pct)] ${pct}%"
                row=$((row+1))
                line $row "   $(fmt_bytes $cur_bytes) / $(fmt_bytes $cur_size)"
                row=$((row+1))
            else
                if [ "$expected" -gt 0 ]; then
                    pct=$(( loaded_count * 100 / expected ))
                else pct=0; fi
                eta_str=""
                if [ -n "$eta_sec" ] && [ "$eta_sec" -gt 0 ]; then
                    eta_str="   ETA $(fmt_dur $eta_sec)"
                fi
                line $row "   $spinner  Unpacking images to Docker storage"
                row=$((row+1))
                line $row "   [$(bar $pct)] ${pct}%"
                row=$((row+1))
                line $row "   ${loaded_count}/${expected} images${eta_str}"
                row=$((row+1))
            fi

            line $row ""; row=$((row+1))

            IFS=',' read -ra all_imgs <<< "$images_csv"
            done_str=",${done_csv},"
            active_seen=0
            for img in "${all_imgs[@]}"; do
                [ -z "$img" ] && continue
                if [[ "$done_str" == *",${img},"* ]]; then
                    line $row "      \e[32m✓\e[0m  $img"
                elif [ "$active_seen" -eq 0 ]; then
                    line $row "      \e[33m$spinner\e[0m  $img"
                    active_seen=1
                else
                    line $row "      \e[2m·  $img\e[0m"
                fi
                row=$((row+1))
            done
            ;;
        done)
            line $row "   \e[32m✓\e[0m  All images loaded."; row=$((row+1))
            ;;
        failed)
            line $row "   \e[31m✗  Setup FAILED — see journalctl -u nomad-init\e[0m"
            row=$((row+1))
            ;;
        *)
            line $row "   $spinner  $init_phase"; row=$((row+1))
            ;;
    esac

    # Erase any stale rows from previous (longer) frames.
    max_row=${max_row:-$PROGRESS_ROW}
    while [ "$row" -le "$max_row" ]; do
        line $row ""; row=$((row+1))
    done
    max_row=$row

    sleep 0.25
done

# init done — capture exit code
wait "$INIT_PID"
init_rc=$?

if [ "$init_rc" -ne 0 ]; then
    line $((PROGRESS_ROW + 15)) ""
    line $((PROGRESS_ROW + 16)) "   \e[31m✗  Setup failed (exit $init_rc)\e[0m"
    line $((PROGRESS_ROW + 17)) "   Diagnostic: journalctl -u nomad-init -n 100"
    line $((PROGRESS_ROW + 18)) "   The system will NOT reboot automatically."
    line $((PROGRESS_ROW + 19)) "   You can SSH in (user: nomad / pass: nomad) to inspect."
    sleep 60     # give user a chance to read before any auto-action
    exit "$init_rc"
fi

# Success — mark the flag, briefly show "complete", reboot.
mkdir -p "$(dirname "$FLAG_FILE")"
touch "$FLAG_FILE"

clear 2>/dev/null || true
cat <<EOF


   ╔══════════════════════════════════════════════════════════════════╗
   ║                                                                  ║
   ║          ✓  SETUP COMPLETE                                       ║
   ║                                                                  ║
   ║          Rebooting in 5 seconds...                               ║
   ║                                                                  ║
   ╚══════════════════════════════════════════════════════════════════╝


EOF

sleep 5
systemctl reboot
