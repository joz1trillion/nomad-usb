#!/bin/bash
#
# nomad-init: runs exactly once per USB, on first boot.
# Loads docker-image tarballs the flash tool placed in
# /mnt/nomad-data/images/ so containers are ready offline.
#
# This script is intentionally SILENT to /dev/tty1. Loading 5GB+ of
# images takes 15-20 minutes on USB and we used to splat that progress
# all over the screen, which was annoying after Nomad came up because
# every container start also printed kernel messages over whatever you
# were looking at. Now: progress goes to two places only:
#
#   - the systemd journal (boring, queryable later)
#   - /run/nomad-init.state (a structured file `nomad watch` reads)
#
# Users who want to see progress run `nomad watch` from any TTY/SSH.

set -uo pipefail

IMAGES_DIR="/mnt/nomad-data/images"
STATUS_FILE="/run/nomad-status"      # one-line summary, legacy
STATE_FILE="/run/nomad-init.state"   # structured key=value, parseable
PV_BYTES_FILE="/run/nomad-init.pv"   # current bytes-through-pipe
LOG_FILE="/run/nomad-init.log"       # docker load output for debugging

# Write a status line to journal + the legacy STATUS_FILE.
# No tty1 anymore — `nomad watch` is the way to follow progress.
say() {
    local msg="$1"
    echo "[nomad-init] $msg"
    echo "$msg" > "$STATUS_FILE" 2>/dev/null || true
}

# Write a structured key=value pair into STATE_FILE. We use a simple
# rewrite-in-place model: read all current lines, drop any matching
# the same key, append the new line, atomic-rename. Cheap on tmpfs.
#
# We chmod 644 after the rename: mktemp creates files mode 600, and
# `mv` preserves the source permissions. Without this, `nomad watch`
# running as the (unprivileged) nomad user can't read state and
# silently falls back to the empty view — the symptom is `nomad watch`
# showing zero images and the "post-init" docker ps table even while
# init is still running.
set_state() {
    local key="$1" val="$2"
    local tmp
    tmp=$(mktemp)
    if [ -f "$STATE_FILE" ]; then
        grep -v "^${key}=" "$STATE_FILE" > "$tmp" 2>/dev/null || true
    fi
    printf '%s=%s\n' "$key" "$val" >> "$tmp"
    mv "$tmp" "$STATE_FILE"
    chmod 644 "$STATE_FILE" 2>/dev/null || true
}

# Initial state. Everything cleared so a previous run's state can't
# bleed into this one (matters during dev when we're testing).
# Set 644 perms here too so the empty-init versions are also readable.
mkdir -p "$(dirname "$STATE_FILE")"
: > "$STATE_FILE"
: > "$PV_BYTES_FILE"
: > "$LOG_FILE"
chmod 644 "$STATE_FILE" "$PV_BYTES_FILE" "$LOG_FILE" 2>/dev/null || true
set_state phase init

# ---- early-exit cases ----
if [ ! -d "$IMAGES_DIR" ]; then
    say "no images directory at $IMAGES_DIR, skipping"
    set_state phase skipped
    exit 0
fi

shopt -s nullglob
tars=("$IMAGES_DIR"/*.tar)

if [ ${#tars[@]} -eq 0 ]; then
    say "no image tarballs to load"
    set_state phase skipped
    exit 0
fi

# ---- compute totals + extract image names from manifest(s) ----
# docker save tarballs have a manifest.json at the top level. Each
# entry's RepoTags array tells us the friendly image name. We
# pre-extract these so `nomad watch` can show the full image list
# with pending/active/done state for each, even before docker load
# has touched any of them.
total_bytes=0
all_images=()
for tar in "${tars[@]}"; do
    sz=$(stat -c %s "$tar" 2>/dev/null || echo 0)
    total_bytes=$((total_bytes + sz))

    if command -v jq >/dev/null 2>&1; then
        # Pull the first RepoTag from each manifest entry. Some entries
        # have multiple tags (same image, multiple names) — we just
        # take the first to keep the display clean.
        while IFS= read -r tag; do
            [ -n "$tag" ] && all_images+=("$tag")
        done < <(tar -xOf "$tar" manifest.json 2>/dev/null \
                 | jq -r '.[].RepoTags[0] // empty' 2>/dev/null || true)
    fi
done

expected_images=${#all_images[@]}
total_mb=$((total_bytes / 1024 / 1024))

set_state total_bytes "$total_bytes"
set_state expected_images "$expected_images"
# images=name1,name2,name3 — comma-separated single line for easy parsing
IFS=','; set_state images "${all_images[*]}"; IFS=$' \t\n'

say "loading ${#tars[@]} tarball(s), ${total_mb} MB total, $expected_images image(s)"

# ---- the load loop ----
idx=0
loaded_total=0      # cumulative across all tarballs
load_start_ts=$(date +%s)
set_state load_start_ts "$load_start_ts"

for tar in "${tars[@]}"; do
    idx=$((idx + 1))
    sz=$(stat -c %s "$tar" 2>/dev/null || echo 0)
    mb=$((sz / 1024 / 1024))
    say "tarball ${idx}/${#tars[@]}: $(basename "$tar") (${mb} MB)"
    set_state phase reading
    set_state current_tarball "$idx"
    set_state current_tarball_size "$sz"

    # Reset pv bytes file for this tarball — pv writes one line of
    # numbers (current bytes processed) once a second. nomad watch
    # tail-reads this for the phase-1 progress bar.
    : > "$PV_BYTES_FILE"

    # ---- run pv | docker load in background ----
    # pv -n -b prints raw bytes-so-far number, one per second, to
    # stderr. We redirect that to PV_BYTES_FILE. nomad watch reads
    # the last line of that file to draw a real-time progress bar.
    if command -v pv >/dev/null 2>&1; then
        ( pv -n -b -i 1 -s "$sz" "$tar" 2>"$PV_BYTES_FILE" \
          | docker load >> "$LOG_FILE" 2>&1 ) &
    else
        ( docker load < "$tar" >> "$LOG_FILE" 2>&1 ) &
    fi
    LOAD_PID=$!

    # ---- poll loop: track per-image unpack progress ----
    # docker load prints "Loaded image: <name>" to stdout each time
    # it finishes unpacking one. We tail $LOG_FILE looking for those
    # and update STATE_FILE so watch can render the per-image list.
    #
    # HANG WORKAROUND: docker load sometimes hangs at the END of a
    # large tarball — all images are loaded and visible in `docker
    # images`, but the docker load process itself never exits.
    # Observed on Trixie's docker.io with our ~5GB tarball; appears
    # to be a daemon-side issue with finalization.
    #
    # Without this workaround, init blocks forever; nomad-start
    # never runs; the user sees "loading tarball" until they reboot.
    #
    # Workaround: once all expected images are loaded AND docker load
    # has been idle (no new "Loaded image:" lines) for HANG_TIMEOUT
    # seconds, declare victory and SIGTERM the process. The work IS
    # done — `docker images` shows everything — we're just unwedging
    # a stuck flush.
    HANG_TIMEOUT=90
    last_count=0
    last_progress_ts=$(date +%s)

    while kill -0 "$LOAD_PID" 2>/dev/null; do
        # Count finished images in the log so far.
        loaded=$(grep -c '^Loaded image' "$LOG_FILE" 2>/dev/null || echo 0)
        loaded=${loaded//[^0-9]/}
        loaded=${loaded:-0}

        if [ "$loaded" != "$last_count" ]; then
            # Pull the loaded names. Format: "Loaded image: name:tag" or
            # "Loaded image ID: sha256:..." — we want the names. The
            # ID-form happens for layers without tags, which is normal
            # for docker save'd images and we just skip those.
            done_names=$(grep '^Loaded image:' "$LOG_FILE" 2>/dev/null \
                         | sed 's/^Loaded image: //' \
                         | tr '\n' ',' | sed 's/,$//')
            set_state done_images "$done_names"
            set_state loaded_count "$((loaded_total + loaded))"

            now=$(date +%s)
            elapsed=$((now - load_start_ts))
            cumulative=$((loaded_total + loaded))
            if [ "$cumulative" -gt 0 ] && [ "$expected_images" -gt 0 ]; then
                remaining=$((expected_images - cumulative))
                if [ "$remaining" -lt 0 ]; then remaining=0; fi
                eta_sec=$(( elapsed * remaining / cumulative ))
                set_state eta_sec "$eta_sec"
            fi

            set_state phase unpacking
            last_count=$loaded
            last_progress_ts=$(date +%s)
        else
            # No new images this tick. Check for the hang condition:
            # all expected images loaded AND no progress for a while.
            if [ "$expected_images" -gt 0 ] && [ "$loaded" -ge "$expected_images" ]; then
                idle=$(( $(date +%s) - last_progress_ts ))
                if [ "$idle" -ge "$HANG_TIMEOUT" ]; then
                    say "all $expected_images images loaded; docker load idle ${idle}s, unwedging"
                    # SIGTERM first; if it doesn't die quickly, SIGKILL.
                    kill -TERM "$LOAD_PID" 2>/dev/null || true
                    sleep 2
                    kill -KILL "$LOAD_PID" 2>/dev/null || true
                    # The wait below will return non-zero (signal exit
                    # codes are 128 + signum). We treat that as success
                    # because we know the work completed — see below.
                    break
                fi
            fi
        fi

        sleep 1
    done

    # Capture exit code. If we killed the process due to a hang after
    # all images loaded, the exit code will be non-zero (probably 143
    # for SIGTERM or 137 for SIGKILL). That's fine — the load
    # actually succeeded, we just had to evict a stuck process.
    wait "$LOAD_PID" 2>/dev/null
    load_rc=$?

    # Verify by counting again: if expected_images are present in the
    # log, we're good regardless of how docker load exited. Only treat
    # as a real failure if the image count is short.
    final=$(grep -c '^Loaded image' "$LOG_FILE" 2>/dev/null || echo 0)
    final=${final//[^0-9]/}
    final=${final:-0}

    if [ "$expected_images" -gt 0 ] && [ "$final" -lt "$expected_images" ]; then
        say "tarball ${idx} load failed: only $final/$expected_images images loaded (exit $load_rc)"
        set_state phase failed
        exit 1
    fi

    # Track cumulative image count across multiple tarballs (in case
    # we ever ship multiple tar files instead of one big nomad.tar).
    loaded_total=$final

    say "tarball ${idx}/${#tars[@]} done ($final images)"
done

set_state phase done
set_state loaded_count "$loaded_total"
say "image load complete: $loaded_total images loaded"
